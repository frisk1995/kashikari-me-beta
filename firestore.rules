rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /groups/{groupId} {
      allow read: if true;
      allow write: if true;
      match /payments/{paymentId} {
        allow read, write: if true;
      }
    }
  }
}
